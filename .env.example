# Discord bot token — from https://discord.com/developers/applications > Bot > Token
DISCORD_TOKEN=your-discord-bot-token

# The channel ID of #gm-gn (right-click the channel > Copy Channel ID, needs Developer Mode on)
GM_CHANNEL_ID=123456789012345678

# Your Alva API key — from https://alva.ai/apikey
ALVA_API_KEY=alva_...

# Optional: Application ID — needed for register-commands.js
DISCORD_CLIENT_ID=your-application-id

# Optional: Register /gm command only in this server (instant, no wait)
DISCORD_GUILD_ID=your-server-id

# Optional: Cron schedule for GM post (default: 8:00 AM UTC daily)
# See https://crontab.guru for help
# GM_CRON=0 8 * * *
